APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000

DATABASE_URL=postgresql+psycopg://pkb:pkb@localhost:5432/pkb
POSTGRES_DB=pkb
POSTGRES_USER=pkb
POSTGRES_PASSWORD=pkb

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=pkb_chunks
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=pkb_chunks

STORAGE_DOCS_PATH=storage/docs

# Embedding. Default "local" runs bge-small-zh-v1.5 in-process (512-dim, safe; no
# network after the one-time model download). To use the Aliyun Model Studio API:
# set EMBEDDING_PROVIDER=openai, EMBEDDING_MODEL=qwen3.7-text-embedding,
# EMBEDDING_DIMENSIONS=1024, EMBEDDING_API_KEY=<DashScope key> (EMBEDDING_API_BASE_URL
# below is pre-filled and ignored while provider=local), and drop the existing Qdrant
# collection to recreate at 1024. EMBEDDING_DIMENSIONS MUST match the model or upsert
# fails on a size mismatch.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSIONS=512
EMBEDDING_API_BASE_URL=https://llm-ma8f7y5ak6voybg0.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=

# Cross-encoder reranker. Default RERANKER_PROVIDER=api calls the Aliyun Model Studio
# /reranks endpoint (compatible-api path - distinct from embeddings' compatible-mode;
# RERANKER_API_KEY reuses EMBEDDING_API_KEY when empty, so with no key set it degrades
# to no rerank and retrieval returns RRF-fused hits). provider=local runs Qwen3-Reranker
# in-process; RERANKER_ENABLED=false skips reranking entirely.
RERANKER_ENABLED=true
RERANKER_PROVIDER=api
RERANKER_MODEL=qwen3-rerank
RERANKER_API_BASE_URL=https://llm-ma8f7y5ak6voybg0.cn-beijing.maas.aliyuncs.com/compatible-api/v1
RERANKER_API_KEY=

# Retrieval tuning: RRF constant k, and how many hits each backend fetches before rerank.
RRF_K=60
RERANK_TOP_K=20

# LLM for cited answers (OpenAI-compatible /chat/completions on the compatible-mode
# path). deepseek-v4-flash is a reasoning model on this instance (also available:
# qwen3.7-plus, qwen3.7-max, glm-5.2, kimi-k3). Leave LLM_API_KEY empty to fall back to
# SimpleAnswerGenerator (returns matched chunks, no network).
LLM_API_BASE_URL=https://llm-ma8f7y5ak6voybg0.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash

# Allowed browser origins for the API as a JSON array (web app origin by default).
CORS_ORIGINS=["http://localhost:3000"]

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
