APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
WEB_PORT=3000

DATABASE_URL=postgresql+psycopg://pkb:pkb@localhost:5432/pkb
POSTGRES_DB=pkb
POSTGRES_USER=pkb
POSTGRES_PASSWORD=pkb

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=pkb_chunks
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=pkb_chunks

STORAGE_DOCS_PATH=storage/docs

# Embedding. "local" runs bge-small-zh-v1.5 in-process (default, no network after the
# one-time model download); "openai" routes to an OpenAI-compatible /embeddings endpoint
# (set EMBEDDING_API_* and EMBEDDING_MODEL). EMBEDDING_DIMENSIONS MUST match the model
# (512 for bge-small-zh-v1.5) or Qdrant collection creation fails on a size mismatch.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSIONS=512
EMBEDDING_API_BASE_URL=
EMBEDDING_API_KEY=

# Cross-encoder reranker (Qwen3-Reranker-0.6B). Set RERANKER_ENABLED=false to skip the
# model load for fast smoke tests; retrieval then returns RRF-fused hits directly.
RERANKER_ENABLED=true
RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B

# Retrieval tuning: RRF constant k, and how many hits each backend fetches before rerank.
RRF_K=60
RERANK_TOP_K=20

# LLM for cited answers (OpenAI-compatible /chat/completions). Leave unset to return the
# matched chunks as the answer (SimpleAnswerGenerator, no network).
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Comma-separated allowed browser origins for the API (web app origin by default).
CORS_ORIGINS=http://localhost:3000

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
